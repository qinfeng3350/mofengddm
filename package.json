{
  "name": "mofengddm",
  "version": "1.0.0",
  "private": true,
  "description": "墨枫低代码平台",
  "scripts": {
    "predev": "node scripts/free-ports.js 4000 3000",
    "dev": "concurrently -n \"后端,前端\" -c \"blue,green\" \"pnpm --filter core dev\" \"pnpm --filter portal dev\"",
    "predev:backend": "node scripts/free-ports.js 4000",
    "dev:backend": "pnpm --filter core dev",
    "dev:frontend": "pnpm --filter portal dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "pnpm --filter portal build",
    "build:backend": "pnpm --filter core build",
    "start": "node services/core/dist/main.js",
    "prestart:prod": "node scripts/free-ports.js 4000",
    "start:prod": "pnpm --filter core run start:prod",
    "prestart:bt": "node scripts/free-ports.js 4000",
    "start:bt": "pnpm --filter core run start:prod",
    "bt:build": "NODE_OPTIONS=--max-old-space-size=4096 pnpm --filter portal build && pnpm --filter core build",
    "bt:run": "pnpm run bt:build && pnpm run start:bt",
    "install:all": "pnpm install",
    "clean": "pnpm --filter core clean && pnpm --filter portal clean",
    "clean:dist": "rm -rf services/core/dist apps/portal/dist",
    "audit": "pnpm audit --audit-level=high",
    "migrate:comments:once": "pnpm --filter core run migrate:comments:once"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
