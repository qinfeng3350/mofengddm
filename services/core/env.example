# 前端门户地址（钉钉待办/消息里的「打开详情」链接，必须公网可访问）
# 示例：https://ddm.mofeng33506.xyz  或 内网穿透域名（与浏览器访问 Portal 的地址一致，不要尾斜杠）
PORTAL_BASE_URL=

# 钉钉 Stream 模式（事件订阅/回调通道）
# ClientID/ClientSecret 即 AppKey/AppSecret
DINGTALK_STREAM_CLIENT_ID=
DINGTALK_STREAM_CLIENT_SECRET=

# 注册邀请码（用于控制是否允许通过 /api/auth/register 注册）
# 前端注册页需要填写；若为空则完全禁止注册
REGISTER_INVITE_CODE=

# ============= Licensing / Installation (licenseKey + installation secret)
# 用于对 licenseKey 进行签名验签（建议只在全局管理/授权服务端配置）
LICENSE_SIGN_SECRET=

# 全局管理后台生成 licenseKey 时使用（请求头：`x-admin-secret`）
LICENSE_ADMIN_SECRET=

# 部署/安装写入本地租户 metadata 时使用（请求头：`x-install-secret`）
LICENSE_INSTALL_SECRET=

